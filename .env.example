# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Paystack
PAYSTACK_SECRET_KEY=sk_live_or_test_your_key

# Exchange rate fetched from MoneyConvert.net (free, no key needed)
# Cached in Upstash Redis for 5 minutes

# Resend (email)
RESEND_API_KEY=re_your_resend_key
ADMIN_EMAIL=admin@yourdomain.com

# Admin alerts — shared secret sent as the `x-admin-alert-secret` request
# header by internal callers (e.g. /api/webhooks/paystack, the exchange rate
# fallback chain in /api/paystack/initialize) to authenticate against
# /api/admin/alerts. Generate a strong random string (e.g. `openssl rand -hex 32`)
# and use the SAME value here as you set in Vercel project env vars.
ADMIN_ALERT_SECRET=replace_with_a_strong_random_secret

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# App
# Use http://localhost:3000 for local development
NEXT_PUBLIC_APP_URL=https://surveyconnect.vercel.app
